<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/main"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <!-- Contenu principal -->
    <FrameLayout
        android:id="@+id/containerContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== BARRE PROFIL EN HAUT ===== -->
            <LinearLayout
                android:id="@+id/topBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <!-- Avatar + Niveau -->
                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp">

                    <ImageView
                        android:id="@+id/avatarImage"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/avatar"
                        android:background="@drawable/avatar_background"
                        android:scaleType="centerCrop"/>

                    <TextView
                        android:id="@+id/playerLevel"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/score_box_bacground"
                        android:text="1"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginTop="8dp">

                    <!-- Petit espace entre icône et animation -->
                    <Space
                        android:layout_width="8dp"
                        android:layout_height="wrap_content"/>

                    <!-- Animation Lottie -->
                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/welcomeAnimation"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/welcome" />
                </LinearLayout>


            </LinearLayout>

            <!-- ===== TITRE ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:paddingBottom="50dp"
                android:text=" TO 2048 GAME "
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="30sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"/>

            <!--- section cartes -->

            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp">

                <!-- Carte 1 : Débuter -->
                <FrameLayout
                    android:id="@+id/btnOnePlayer"
                    android:layout_width="0dp"
                    android:layout_weight="0.4"
                    android:layout_height="110dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/carte_menu"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Animation Lottie centrée en haut -->
                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="8dp"
                        app:lottie_rawRes="@raw/debuter"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"/>

                    <!-- Bande colorée en bas -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/carte_menu_bande"
                        android:text="DÉBUTER"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                </FrameLayout>

                <!-- Carte 2 : Jouer à deux -->
                <FrameLayout
                    android:id="@+id/btnTwoPlayers"
                    android:layout_width="0dp"
                    android:layout_weight="0.4"
                    android:layout_height="110dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/carte_menu"
                    android:clickable="true"
                    android:focusable="true">

                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="8dp"
                        app:lottie_rawRes="@raw/two_people"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/carte_menu_bande"
                        android:text="JOUER À DEUX"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp">

                <!-- Carte 3 : Classement -->
                <FrameLayout
                    android:id="@+id/btnClassement"
                    android:layout_width="0dp"
                    android:layout_weight="0.4"
                    android:layout_height="110dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/carte_menu"
                    android:clickable="true"
                    android:focusable="true">

                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="8dp"
                        app:lottie_rawRes="@raw/classement"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/carte_menu_bande"
                        android:text="CLASSEMENT"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                </FrameLayout>

                <!-- Carte 4 : Inviter -->
                <FrameLayout
                    android:id="@+id/btnInvite"
                    android:layout_width="0dp"
                    android:layout_weight="0.4"
                    android:layout_height="110dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/carte_menu"
                    android:clickable="true"
                    android:focusable="true">

                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="110dp"
                        android:layout_height="80dp"
                        android:layout_gravity="top|center_horizontal"
                        android:layout_marginTop="8dp"
                        app:lottie_rawRes="@raw/invite"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/carte_menu_bande"
                        android:text="INVITER"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/bottomRightAnimation"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="85dp"
        app:lottie_rawRes="@raw/game"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintWidth_default="wrap"
        app:layout_constraintDimensionRatio="H,1:1"/>

    <!-- Bottom Navigation -->
    <nl.joery.animatedbottombar.AnimatedBottomBar
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:background="@drawable/bottom_nav_background"
        app:abb_selectedTabType="text"
        app:abb_indicatorAppearance="round"
        app:abb_indicatorColor="@color/bottom_nav_item_selected_light"
        app:abb_indicatorHeight="4dp"
        app:abb_indicatorMargin="8dp"
        app:abb_tabColor="@color/bottom_nav_item_light"
        app:abb_tabColorSelected="@color/bottom_nav_item_selected_light"
        app:abb_tabs="@menu/activity_menu_bar"
        app:abb_selectedIndex="0"
        app:abb_animationDuration="300"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <view
        android:id="@+id/view"
        class="com.example.jeu2048.gameRender.GameView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />
</androidx.constraintlayout.widget.ConstraintLayout>