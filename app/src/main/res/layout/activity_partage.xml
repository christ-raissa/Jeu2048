<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="50dp"
    android:paddingBottom="50dp"
    android:background="?attr/android:windowBackground">

    <TextView
        android:id="@+id/tvTitrePartage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="QUELLE PARTIE DÉSIREZ-VOUS PARTAGER ?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="?android:attr/textColorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ListView
        android:id="@+id/listParties"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:divider="@color/separateur"
        android:dividerHeight="1dp"
        android:choiceMode="singleChoice"
        app:layout_constraintTop_toBottomOf="@id/tvTitrePartage"
        app:layout_constraintBottom_toTopOf="@id/btnPartager"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPartager"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:text="PARTAGER"
        android:background="@drawable/bouton_filled"
        android:textColor="?attr/colorOnPrimary"
        app:cornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>