<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp"
    android:background="?attr/android:windowBackground">
    android:padding="16dp">

    <!-- ===== ZONE JOUEUR 2 (haut, retournée à 180°) ===== -->
    <LinearLayout
        android:id="@+id/zone2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:rotation="180"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <GridLayout
            android:id="@+id/gridPlayer2"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:columnCount="3"
            android:rowCount="3"
            android:background="@drawable/grid_background"
            android:padding="6dp">

            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
        </GridLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/score_box_bacground"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCORE"
                    android:textColor="#EEE4DA"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/p2Score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/score_box_bacground"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST"
                    android:textColor="#EEE4DA"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/p2Best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== ESPACE CENTRAL ===== -->
    <Space
        android:id="@+id/centerSpace"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        app:layout_constraintTop_toBottomOf="@id/zone2"
        app:layout_constraintBottom_toTopOf="@id/zone1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ===== ZONE JOUEUR 1 (bas, sens normal) ===== -->
    <LinearLayout
        android:id="@+id/zone1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <GridLayout
            android:id="@+id/gridPlayer1"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:columnCount="3"
            android:rowCount="3"
            android:background="@drawable/grid_background"
            android:padding="6dp">

            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
            <TextView android:layout_width="0dp" android:layout_height="0dp"
                android:layout_rowWeight="1" android:layout_columnWeight="1"
                android:layout_margin="4dp" android:background="@drawable/title_2048"
                android:gravity="center" android:textStyle="bold" android:textSize="18sp"/>
        </GridLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/score_box_bacground"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCORE"
                    android:textColor="#EEE4DA"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/p1Score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/score_box_bacground"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEST"
                    android:textColor="#EEE4DA"
                    android:textSize="11sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/p1Best"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>