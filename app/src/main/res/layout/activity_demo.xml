<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="35dp"
    android:layout_marginBottom="35dp"
    android:background="?android:windowBackground">

    <!-- IMAGE DE FOND -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/back"
        android:scaleType="centerCrop"
        android:alpha="0.08"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bouton Ignorer -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSkip"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="Ignorer"
        android:textColor="?attr/buttonOutlineColor"
        android:textSize="15sp"
        android:background="@drawable/bouton_outline"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="@id/gameContainer"
        app:layout_constraintEnd_toEndOf="@id/gameContainer"/>

    <!-- TITRE -->
    <TextView
        android:id="@+id/stepTitle"
        android:text="Comment jouer ?"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="?android:textColor"
        app:layout_constraintTop_toBottomOf="@id/btnSkip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- CONTAINER VIDEO -->
    <FrameLayout
        android:id="@+id/gameContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="32dp"
        android:background="@color/blackgris"
        app:layout_constraintTop_toBottomOf="@id/stepTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/arrowImage"
        app:layout_constraintDimensionRatio="1:1">

        <VideoView
            android:id="@+id/tutorialVideo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>

    <!-- FLECHE -->
    <ImageView
        android:id="@+id/arrowImage"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/house"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/gameContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- TEXTE -->
    <TextView
        android:id="@+id/messageText"
        android:text="Fusionnez les tuiles pour atteindre 2048"
        android:textSize="16sp"
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="?android:textColor"
        app:layout_constraintTop_toBottomOf="@id/arrowImage"
        app:layout_constraintStart_toStartOf="@id/gameContainer"
        app:layout_constraintEnd_toEndOf="@id/gameContainer"/>

    <!-- BOUTON JOUER -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="Jouer"
        android:textSize="15sp"
        android:textColor="@android:color/white"
        android:background="@drawable/bouton_filled"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintTop_toBottomOf="@id/messageText"
        app:layout_constraintStart_toStartOf="@id/gameContainer"
        app:layout_constraintEnd_toEndOf="@id/gameContainer"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>