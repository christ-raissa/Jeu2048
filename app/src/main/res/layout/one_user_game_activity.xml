<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="15dp"
    android:background="?attr/android:windowBackground"
    android:padding="16dp">

    <!-- ===== BARRE DU HAUT ===== -->

    <!-- Logo + Titre -->
    <ImageView
        android:id="@+id/logoApp"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@mipmap/ic_launcher"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/title2048"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="JEU"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/text_color_light"
        android:layout_marginStart="8dp"
        app:layout_constraintTop_toTopOf="@id/logoApp"
        app:layout_constraintBottom_toBottomOf="@id/logoApp"
        app:layout_constraintStart_toEndOf="@id/logoApp"/>

    <!-- Icônes à droite -->
    <LinearLayout
        android:id="@+id/topIcons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="@id/logoApp"
        app:layout_constraintBottom_toBottomOf="@id/logoApp"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Bouton Classement -->
        <ImageButton
            android:id="@+id/btnClassement"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:srcCompat="@drawable/medail"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/black"
            android:contentDescription="Classement"
            android:layout_marginEnd="8dp"/>

        <!-- Bouton Restart -->
        <ImageButton
            android:id="@+id/btnRestart"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:srcCompat="@drawable/restart"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/black"
            android:contentDescription="Restart"
            android:layout_marginEnd="8dp"/>

        <!-- Bouton Settings -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="30dp"
            android:layout_height="30dp"
            app:srcCompat="@drawable/gear"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/black"
            android:contentDescription="Settings"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/scoreContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/logoApp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Boîte SCORE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/score_box_bacground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCORE"
                android:textColor="#EEE4DA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
            <TextView
                android:id="@+id/scoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Boîte MEILLEUR SCORE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:background="@drawable/score_box_outline"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEILLEUR SCORE"
                android:textColor="#EEE4DA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
            <TextView
                android:id="@+id/bestScoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- GRILLE 4x4 -->
    <GridLayout
        android:id="@+id/gridOneUser"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="4"
        android:rowCount="4"
        android:background="@drawable/grid_background"
        android:padding="6dp"
        app:layout_constraintTop_toBottomOf="@id/scoreContainer"
        app:layout_constraintBottom_toTopOf="@id/gameInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Ligne 1 -->
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>

        <!-- Ligne 2 -->
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>

        <!-- Ligne 3 -->
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>

        <!-- Ligne 4 -->
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="0dp"
            android:layout_rowWeight="1" android:layout_columnWeight="1"
            android:layout_margin="4dp" android:background="@drawable/title_2048"
            android:gravity="center" android:textStyle="bold" android:textSize="20sp"/>
    </GridLayout>

    <!-- ===== TIMER + COUPS (sous la grille) ===== -->
    <LinearLayout
        android:id="@+id/gameInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/gridOneUser"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Timer -->
        <TextView
            android:id="@+id/timerText"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#776E65"/>

        <!-- Nombre de coups -->
        <TextView
            android:id="@+id/movesText"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="0 COUPS"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#776E65"
            android:gravity="end"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>