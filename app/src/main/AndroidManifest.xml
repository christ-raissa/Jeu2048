<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Jeu2048">

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Jeu2048.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.PartageActivity"
            android:exported="false"
            android:label="Partager une partie" />

        <activity
            android:name=".ui.DemoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.StatistiqueActivity"
            android:exported="false" />

        <activity
            android:name=".ui.SettingActivity"
            android:exported="false" />

        <activity
            android:name=".ui.OneUserGameActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.MultiplayerGameActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

    </application>

</manifest>