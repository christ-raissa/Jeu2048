<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Jeu2048">

        <!-- Splash Screen -->
        <activity
            android:name=".ui.SplashActivity"
            android:theme="@style/Theme.Jeu2048.Splash"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Démo du jeu -->
        <activity
            android:name=".ui.DemoActivity"
            android:exported="false"/>

        <!-- Page principale -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"/>

        <!-- Page Inventaire -->
        <activity
            android:name=".ui.StatistiqueActivity"
            android:exported="false"/>

        <!-- Page Users -->
        <activity
            android:name=".ui.UsersActivity"
            android:exported="false"/>

        <!-- Page Paramètres -->
        <activity
            android:name=".ui.SettingActivity"
            android:exported="false"/>

        <activity android:name=".ui.OneUserGameActivity"
            android:exported="false"/>
    </application>

</manifest>